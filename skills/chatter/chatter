#!/usr/bin/env python3
"""chatter — filesystem multi-agent chat helper.

Subcommands:
  post <slug> <agent-id> <content> [--in-reply-to ID]
    content "-" reads body from stdin (use to avoid shell quoting issues).
  read <slug> [--since FILENAME]
  wait <slug> [--timeout SEC]
  loop <slug> <agent-id>
    stateful read/wait loop; prints the next non-self message batch as JSON.

Thread root: --root if given, else $CHATTER_ROOT, else ./agent-chatter.
Messages are markdown files with YAML-style frontmatter.
"""
import argparse
import json
import os
import shutil
import subprocess
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path


def default_root() -> Path:
    env = os.environ.get("CHATTER_ROOT")
    if env:
        return Path(env).expanduser()
    return Path.cwd() / "agent-chatter"


def thread_dir(root: Path, slug: str, must_exist: bool = True, wait_create: float = 0.0) -> Path:
    d = root / slug
    if wait_create > 0 and not d.is_dir():
        deadline = time.time() + wait_create
        while time.time() < deadline:
            if d.is_dir():
                break
            time.sleep(0.5)
    if must_exist and not d.is_dir():
        sys.exit(f"chatter: thread dir not found: {d}")
    return d


def render_msg(meta: dict, content: str) -> str:
    reply = meta.get("in_reply_to") or ""
    return (
        "---\n"
        f"id: {meta['id']}\n"
        f"thread: {meta['thread']}\n"
        f"from: {meta['from']}\n"
        f"in_reply_to: {reply}\n"
        f"created_at: {meta['created_at']}\n"
        "---\n"
        f"{content}"
    )


def parse_msg(text: str) -> dict:
    if not text.startswith("---\n"):
        raise ValueError("missing frontmatter start")
    rest = text[4:]
    end = rest.find("\n---\n")
    if end == -1:
        raise ValueError("missing frontmatter end")
    fm_text = rest[:end]
    body = rest[end + 5:]
    meta: dict = {}
    for line in fm_text.splitlines():
        if not line.strip():
            continue
        k, sep, v = line.partition(":")
        if not sep:
            raise ValueError(f"malformed frontmatter line: {line!r}")
        meta[k.strip()] = v.strip()
    for key in ("id", "thread", "from", "created_at"):
        if not meta.get(key):
            raise ValueError(f"missing frontmatter field: {key}")
    return {
        "id": meta["id"],
        "thread": meta["thread"],
        "from": meta["from"],
        "in_reply_to": meta.get("in_reply_to") or meta.get("reply_to") or None,
        "created_at": meta["created_at"],
        "content": body,
    }


def next_counter(d: Path) -> int:
    n = 0
    for entry in d.iterdir():
        name = entry.name
        if name.startswith(".") or not name.endswith(".md"):
            continue
        prefix = name.split("-", 1)[0]
        if prefix.isdigit():
            n = max(n, int(prefix))
    return n + 1


STALE_TMP_AGE_SECONDS = 3600


def sweep_stale_tmps(d: Path) -> None:
    cutoff = time.time() - STALE_TMP_AGE_SECONDS
    for entry in d.iterdir():
        name = entry.name
        if not (name.startswith(".") and name.endswith(".tmp")):
            continue
        try:
            if entry.stat().st_mtime < cutoff:
                entry.unlink()
        except FileNotFoundError:
            pass


def cmd_post(args) -> int:
    content = sys.stdin.read() if args.content == "-" else args.content
    d = thread_dir(args.root, args.slug, must_exist=False)
    d.mkdir(parents=True, exist_ok=True)
    sweep_stale_tmps(d)
    while True:
        counter = next_counter(d)
        fname = f"{counter:04d}-{args.agent}.md"
        final = d / fname
        tmp = d / f".{fname}.{uuid.uuid4().hex}.tmp"
        try:
            fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_EXCL, 0o644)
        except FileExistsError:
            continue
        try:
            meta = {
                "id": fname[:-3],
                "thread": args.slug,
                "from": args.agent,
                "in_reply_to": args.in_reply_to,
                "created_at": datetime.now().astimezone().isoformat(timespec="seconds"),
            }
            with os.fdopen(fd, "w") as f:
                f.write(render_msg(meta, content))
            parse_msg(tmp.read_text())  # validate before publishing
            try:
                os.link(tmp, final)
            except FileExistsError:
                tmp.unlink()
                continue
            except OSError as e:
                tmp.unlink()
                sys.exit(f"chatter: atomic publish failed (filesystem may not support hard links): {e}")
        except BaseException:
            tmp.unlink(missing_ok=True)
            raise
        tmp.unlink()
        break
    print(fname)
    return 0


def cmd_read(args) -> int:
    d = thread_dir(args.root, args.slug, wait_create=args.wait_create)
    out = read_messages(d, args.since)
    json.dump(out, sys.stdout)
    sys.stdout.write("\n")
    return 0


def agent_state_path(d: Path, agent: str) -> Path:
    safe = "".join(c if c.isalnum() or c in "._-" else "_" for c in agent)
    return d / ".chatter-state" / f"{safe}.json"


def load_last_seen(d: Path, agent: str):
    path = agent_state_path(d, agent)
    try:
        data = json.loads(path.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return None
    last_seen = data.get("last_seen")
    return last_seen if isinstance(last_seen, str) else None


def save_last_seen(d: Path, agent: str, last_seen) -> None:
    if not last_seen:
        return
    path = agent_state_path(d, agent)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{uuid.uuid4().hex}.tmp")
    tmp.write_text(json.dumps({"last_seen": last_seen}, sort_keys=True) + "\n")
    tmp.replace(path)


def read_messages(d: Path, since=None):
    out = []
    for entry in sorted(d.iterdir()):
        name = entry.name
        if name.startswith(".") or not name.endswith(".md"):
            continue
        if since and name <= since:
            continue
        try:
            out.append(parse_msg(entry.read_text()))
        except ValueError as e:
            print(f"chatter: skipping malformed {name}: {e}", file=sys.stderr)
    return out


def cmd_wait(args) -> int:
    d = thread_dir(args.root, args.slug, wait_create=args.wait_create)
    if shutil.which("fswatch"):
        cmd = ["fswatch", "-1", "-l", "0.5", "--event", "Created", str(d)]
    elif shutil.which("inotifywait"):
        cmd = ["inotifywait", "-q", "-e", "create", "-t", str(args.timeout), str(d)]
    else:
        deadline = time.time() + args.timeout
        baseline = {p.name for p in d.iterdir()}
        while time.time() < deadline:
            time.sleep(2)
            if {p.name for p in d.iterdir()} - baseline:
                return 0
        return 1
    try:
        completed = subprocess.run(cmd, timeout=args.timeout, check=False)
        return 0 if completed.returncode == 0 else 1
    except subprocess.TimeoutExpired:
        return 1


def cmd_loop(args) -> int:
    d = thread_dir(args.root, args.slug, wait_create=args.wait_create)
    last_seen = args.since if args.since is not None else load_last_seen(d, args.agent)
    timeout_count = 0
    iterations = 0

    while iterations < args.max_iterations:
        iterations += 1
        msgs = read_messages(d, last_seen)
        if msgs:
            last_seen = msgs[-1]["id"] + ".md"
            save_last_seen(d, args.agent, last_seen)
            new = [m for m in msgs if m["from"] != args.agent]
            if new:
                json.dump({
                    "status": "messages",
                    "thread": args.slug,
                    "agent": args.agent,
                    "last_seen": last_seen,
                    "messages": new,
                }, sys.stdout)
                sys.stdout.write("\n")
                return 0

        wait_args = argparse.Namespace(root=args.root, slug=args.slug, timeout=args.timeout, wait_create=0.0)
        if cmd_wait(wait_args) != 0:
            timeout_count += 1
            if timeout_count >= args.silences:
                json.dump({
                    "status": "silent",
                    "thread": args.slug,
                    "agent": args.agent,
                    "last_seen": last_seen,
                    "silences": timeout_count,
                }, sys.stdout)
                sys.stdout.write("\n")
                return 1

    json.dump({
        "status": "iteration_cap",
        "thread": args.slug,
        "agent": args.agent,
        "last_seen": last_seen,
        "iterations": iterations,
    }, sys.stdout)
    sys.stdout.write("\n")
    return 2


def main() -> None:
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--root", default=None, type=lambda s: Path(s).expanduser(),
                        help="thread root directory (default: $CHATTER_ROOT or ./agent-chatter)")

    p = argparse.ArgumentParser(prog="chatter")
    sub = p.add_subparsers(dest="cmd", required=True)

    pp = sub.add_parser("post", parents=[common], help="write a message")
    pp.add_argument("slug")
    pp.add_argument("agent")
    pp.add_argument("content")
    pp.add_argument("--in-reply-to", default=None)
    pp.set_defaults(func=cmd_post)

    pr = sub.add_parser("read", parents=[common], help="list messages as JSON array")
    pr.add_argument("slug")
    pr.add_argument("--since", default=None, help="only files lex-greater than this")
    pr.add_argument("--wait-create", type=float, default=0.0,
                    help="seconds to wait for thread dir to appear before failing")
    pr.set_defaults(func=cmd_read)

    pw = sub.add_parser("wait", parents=[common], help="block until a new file appears or timeout")
    pw.add_argument("slug")
    pw.add_argument("--timeout", type=int, default=300)
    pw.add_argument("--wait-create", type=float, default=0.0,
                    help="seconds to wait for thread dir to appear before failing")
    pw.set_defaults(func=cmd_wait)

    pl = sub.add_parser("loop", parents=[common], help="stateful read/wait loop for the next non-self messages")
    pl.add_argument("slug")
    pl.add_argument("agent")
    pl.add_argument("--since", default=None, help="start after this filename instead of saved state")
    pl.add_argument("--timeout", type=int, default=300, help="seconds to wait for each silence")
    pl.add_argument("--silences", type=int, default=2, help="silent waits before exiting")
    pl.add_argument("--max-iterations", type=int, default=20)
    pl.add_argument("--wait-create", type=float, default=0.0,
                    help="seconds to wait for thread dir to appear before failing")
    pl.set_defaults(func=cmd_loop)

    args = p.parse_args()
    if args.root is None:
        args.root = default_root()
    sys.exit(args.func(args))


if __name__ == "__main__":
    main()
